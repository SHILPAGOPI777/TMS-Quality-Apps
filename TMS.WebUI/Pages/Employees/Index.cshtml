@page
@model TMS.WebUI.Employees.IndexModel
@{
    ViewData["Title"] = "All Employees";
}

<div class="breadcrumbs">
    <a asp-page="../Index" class="btn btn-primary">Home</a>
    <a class="btn btn-primary disabled">Employee list</a>
</div>

<h1>Employees</h1>

<table class="table">
    <tr><td>ShortName</td><td>FullName</td><td>Role</td></tr>
    @foreach (var item in Model.Employees)
    {
        <tr>
            <td>@item.ShortName</td>
            <td><a asp-page="Detailed" asp-route-id="@item.Id">@item.FullName</a></td>
            <td>@item.RoleName</td>
        </tr>
    }
</table>

@if (User.IsInRole("Admin"))
{
    <a class="btn btn-primary task-add noselect" asp-page="Create">Create New Employee </a>
}
